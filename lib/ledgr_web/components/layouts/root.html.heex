<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default={if(assigns[:current_domain], do: assigns[:current_domain].theme()[:tab_title] || assigns[:current_domain].name(), else: "Ledgr")} suffix="">
      {assigns[:page_title]}
    </.live_title>
    <%= if assigns[:current_domain] && assigns[:current_domain].theme()[:favicon] do %>
      <link rel="icon" type="image/png" href={assigns[:current_domain].theme()[:favicon]} />
    <% end %>
    <%!-- OG / Twitter Card meta tags (storefront pages only) --%>
    <%= if assigns[:current_domain] && assigns[:storefront] do %>
      <% d = assigns[:current_domain] %>
      <% og_title = d.name() %>
      <% og_desc = d.theme()[:og_description] || "#{d.name()} — haz tu pedido en línea." %>
      <% og_img_path = d.theme()[:card_logo] || d.theme()[:sidebar_logo] %>
      <% base_url = LedgrWeb.Endpoint.url() %>
      <meta name="description" content={og_desc} />
      <meta property="og:type" content="website" />
      <meta property="og:site_name" content={og_title} />
      <meta property="og:title" content={og_title} />
      <meta property="og:description" content={og_desc} />
      <%= if og_img_path do %>
        <meta property="og:image" content={"#{base_url}#{og_img_path}"} />
      <% end %>
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content={og_title} />
      <meta name="twitter:description" content={og_desc} />
      <%= if og_img_path do %>
        <meta name="twitter:image" content={"#{base_url}#{og_img_path}"} />
      <% end %>
    <% end %>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <%= if assigns[:current_domain] do %>
      <% t = assigns[:current_domain].theme() %>
      <style>
        :root {
          --sidebar-bg: <%= t.sidebar_bg %>;
          --sidebar-text: <%= t.sidebar_text %>;
          --sidebar-hover: <%= t.sidebar_hover %>;
          --primary: <%= t.primary %>;
          --primary-soft: <%= t.primary_soft %>;
          --bg: <%= t[:bg] || "#fff7f2" %>;
          --bg-surface: <%= t[:bg_surface] || "#fffaf6" %>;
          --border-subtle: <%= t[:border_subtle] || "#f1e4da" %>;
          --border-strong: <%= t[:border_strong] || "#e2cdbd" %>;
          --text-main: <%= t[:text_main] || "#3d2318" %>;
          --text-muted: <%= t[:text_muted] || "#8b6f5b" %>;
          --btn-secondary-bg: <%= t[:btn_secondary_bg] || "#f3e4d8" %>;
          --btn-secondary-text: <%= t[:btn_secondary_text] || "#3d2318" %>;
          --btn-secondary-hover: <%= t[:btn_secondary_hover] || "#ead4c4" %>;
          --btn-primary-hover: <%= t[:btn_primary_hover] || "#703025" %>;
          --shadow-color: <%= t[:shadow_color] || "61, 35, 24" %>;
          --table-header-bg: <%= t[:table_header_bg] || "#fff6ee" %>;
          --gradient-start: <%= t[:gradient_start] || "#fde2d0" %>;
          --gradient-mid: <%= t[:gradient_mid] || "#fff7f2" %>;
          --gradient-end: <%= t[:gradient_end] || "#fffaf5" %>;
        }
      </style>
    <% end %>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const setTheme = (theme) => {
          if (theme === "system") {
            localStorage.removeItem("phx:theme");
            document.documentElement.removeAttribute("data-theme");
          } else {
            localStorage.setItem("phx:theme", theme);
            document.documentElement.setAttribute("data-theme", theme);
          }
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "system");
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "system"));

        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    <%= if assigns[:current_domain] do %>
      <% domain = assigns[:current_domain] %>
      <% prefix = domain.path_prefix() %>
      <% theme = domain.theme() %>
      <%= if assigns[:storefront] do %>
        <!-- Public storefront: branded but no sidebar/auth -->
        <div class="storefront-layout">
          <header class="storefront-header">
            <div class="storefront-header-inner">
              <a href={"/#{domain.slug()}/menu"} class="storefront-logo-link">
                <%= if theme[:sidebar_logo] do %>
                  <img src={theme[:sidebar_logo]} alt={domain.name()} class="storefront-logo-img" onerror="this.style.display='none'" />
                <% else %>
                  <span class="storefront-logo-emoji"><%= domain.logo() %></span>
                  <span class="storefront-brand-name"><%= domain.name() %></span>
                <% end %>
              </a>
              <%= if assigns[:show_search] do %>
                <form method="get" action={"/#{domain.slug()}/menu"} class="storefront-search-form">
                  <div class="storefront-search-wrap">
                    <input
                      type="text"
                      name="q"
                      value={assigns[:current_q] || ""}
                      placeholder="Buscar productos…"
                      class="storefront-search-input"
                      autocomplete="off"
                    />
                    <button type="submit" class="storefront-search-btn" aria-label="Buscar">
                      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="11" cy="11" r="8"/>
                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                      </svg>
                    </button>
                  </div>
                </form>
              <% end %>
              <% cart = Plug.Conn.get_session(@conn, :cart) || %{} %>
              <% cart_count = cart |> Map.values() |> Enum.sum() %>
              <a href={"/#{domain.slug()}/cart"} class="storefront-cart-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                  <line x1="3" y1="6" x2="21" y2="6"/>
                  <path d="M16 10a4 4 0 0 1-8 0"/>
                </svg>
                <%= if cart_count > 0 do %>
                  <span class="storefront-cart-badge"><%= cart_count %></span>
                <% end %>
              </a>
            </div>
          </header>
          <main class="storefront-content">
            <%= @inner_content %>
          </main>
          <footer class="storefront-footer">
            <p>&copy; <%= Date.utc_today().year %> <%= domain.name() %></p>
            <div class="storefront-social-links">
              <a href="https://www.instagram.com/mr.munchme/" target="_blank" rel="noopener noreferrer" class="storefront-social-link" title="Instagram">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </a>
              <a href="https://wa.me/525543417149" target="_blank" rel="noopener noreferrer" class="storefront-social-link" title="WhatsApp">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
                </svg>
              </a>
            </div>
            <a href="/app/mr-munch-me" class="storefront-admin-link" title="Admin">&#128274;</a>
          </footer>
        </div>
      <% else %>
      <%= if assigns[:hide_sidebar] do %>
        <!-- Auth pages: clean centered layout, no sidebar -->
        <main class="login-layout">
          <%= @inner_content %>
        </main>
      <% else %>
      <div class="app-layout">
        <!-- Mobile hamburger button -->
        <button class="hamburger-btn" id="hamburger-btn" aria-label="Open menu" aria-expanded="false">
          <span class="hamburger-icon"></span>
        </button>
        <!-- Mobile overlay -->
        <div class="sidebar-overlay" id="sidebar-overlay"></div>

        <aside class="sidebar" id="sidebar">
          <.link navigate={prefix}>
            <div class="sidebar-header">
              <%= if theme[:sidebar_logo] do %>
                <img src={theme[:sidebar_logo]} alt={domain.name()} class="sidebar-logo-img" onerror="this.style.display='none'" />
              <% else %>
                <span class="app-logo"><%= domain.logo() %></span>
                <span class="app-title"><%= domain.name() %></span>
              <% end %>
            </div>
          </.link>

          <nav class="nav">
            <!-- Domain-specific menu groups -->
            <%= for group <- domain.menu_items() do %>
              <div class="nav-dropdown" data-default-open={if group.group in ["Main Menu", "Travel"], do: "true"}>
                <button type="button" class="nav-dropdown-toggle" onclick="toggleDropdown(this)">
                  <span><%= group.group %></span>
                  <.icon name="hero-chevron-down" class="dropdown-icon" />
                </button>
                <div class="nav-dropdown-menu">
                  <%= for item <- group.items do %>
                    <.link navigate={item.path} class="nav-link"><%= item.label %></.link>
                  <% end %>
                </div>
              </div>
            <% end %>

            <!-- Core menu groups (shared across all domains) -->
            <div class="nav-dropdown">
              <button type="button" class="nav-dropdown-toggle" onclick="toggleDropdown(this)">
                <span>Reports</span>
                <.icon name="hero-chevron-down" class="dropdown-icon" />
              </button>
              <div class="nav-dropdown-menu">
                <.link navigate={"#{prefix}/reports/pnl"} class="nav-link">P&L</.link>
                <.link navigate={"#{prefix}/reports/balance_sheet"} class="nav-link">Balance Sheet</.link>
                <.link navigate={"#{prefix}/reports/unit_economics_list"} class="nav-link">Unit Economics</.link>
                <.link navigate={"#{prefix}/reports/cash_flow"} class="nav-link">Cash Flow</.link>
                <.link navigate={"#{prefix}/reports/financial_analysis"} class="nav-link">Financial Analysis</.link>
                <.link navigate={"#{prefix}/account-transactions"} class="nav-link">Account Transactions</.link>
                <.link navigate={"#{prefix}/reports/ap_summary"} class="nav-link">AP Summary</.link>
              </div>
            </div>

            <div class="nav-dropdown">
              <button type="button" class="nav-dropdown-toggle" onclick="toggleDropdown(this)">
                <span>Reconciliation Tools</span>
                <.icon name="hero-chevron-down" class="dropdown-icon" />
              </button>
              <div class="nav-dropdown-menu">
                <.link navigate={"#{prefix}/reconciliation/accounting"} class="nav-link">Account Reconciliation</.link>
                <.link navigate={"#{prefix}/reconciliation/inventory"} class="nav-link">Inventory Reconciliation</.link>
              </div>
            </div>

            <% domain_has_customers = domain.menu_items() |> Enum.flat_map(& &1.items) |> Enum.any?(& &1.path == "#{prefix}/customers") %>
            <div class="nav-dropdown">
              <button type="button" class="nav-dropdown-toggle" onclick="toggleDropdown(this)">
                <span>Other</span>
                <.icon name="hero-chevron-down" class="dropdown-icon" />
              </button>
              <div class="nav-dropdown-menu">
                <%= unless domain_has_customers do %>
                  <.link navigate={"#{prefix}/customers"} class="nav-link">Customers</.link>
                <% end %>
                <.link navigate={"#{prefix}/investments"} class="nav-link">Investments</.link>
                <.link navigate={"#{prefix}/transfers"} class="nav-link">Money Transfers</.link>
                <.link navigate={"#{prefix}/transactions"} class="nav-link">All Transactions</.link>
              </div>
            </div>

          </nav>

          <div class="sidebar-footer">
            <%= if assigns[:current_user] do %>
              <span class="sidebar-user-email"><%= assigns[:current_user].email %></span>
              <.link href={"#{prefix}/logout"} method="delete" class="app-switcher-link logout-link">
                <.icon name="hero-arrow-right-on-rectangle" class="app-switcher-icon" />
                <span>Sign Out</span>
              </.link>
            <% end %>
            <a href="/" class="app-switcher-link">
              <.icon name="hero-arrows-right-left" class="app-switcher-icon" />
              <span>Switch App</span>
            </a>
          </div>
        </aside>

        <main class="content">
          <section class="content-body">
            <%= @inner_content %>
          </section>
        </main>
      </div>
      <% end %>
      <% end %>
    <% else %>
      <!-- No domain context (landing page, etc.) -->
      <main>
        <%= @inner_content %>
      </main>
    <% end %>
    <%!-- Flash toast notifications --%>
    <% flash_info  = Phoenix.Flash.get(@flash, :info) %>
    <% flash_error = Phoenix.Flash.get(@flash, :error) %>
    <%= if flash_info || flash_error do %>
      <div class="flash-container" id="flash-container">
        <%= if flash_info do %>
          <div class="flash-toast flash-toast-info" data-flash-auto-dismiss>
            <span class="flash-toast-icon">✓</span>
            <span class="flash-toast-message"><%= flash_info %></span>
            <button type="button" class="flash-toast-close" onclick="this.closest('.flash-toast').classList.add('hiding'); setTimeout(()=>this.closest('.flash-toast').remove(), 350)">✕</button>
          </div>
        <% end %>
        <%= if flash_error do %>
          <div class="flash-toast flash-toast-error" data-flash-auto-dismiss>
            <span class="flash-toast-icon">⚠</span>
            <span class="flash-toast-message"><%= flash_error %></span>
            <button type="button" class="flash-toast-close" onclick="this.closest('.flash-toast').classList.add('hiding'); setTimeout(()=>this.closest('.flash-toast').remove(), 350)">✕</button>
          </div>
        <% end %>
      </div>
      <script>
        document.querySelectorAll("[data-flash-auto-dismiss]").forEach(function(el) {
          setTimeout(function() {
            el.classList.add("hiding");
            setTimeout(function() { el.remove(); }, 350);
          }, 4500);
        });
      </script>
    <% end %>
  </body>
</html>
