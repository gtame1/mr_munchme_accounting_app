<section class="card">
  <div class="card-header">
    <h2 class="card-title">Expenses</h2>
    <p class="card-subtitle">
      All recorded business expenses — manual entries plus auto-synced costs from
      external services (OpenAI, Whereby, AWS, etc.).
    </p>
  </div>

  <div class="actions" style="margin-bottom: 0.75rem;">
    <.link navigate={dp(@domain_path_prefix, "/expenses/new")} class="btn primary">
      + New Expense
    </.link>
  </div>

  <div class="table-wrapper">
    <table class="table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Source</th>
          <th>Description</th>
          <th>Category</th>
          <th>Expense Account</th>
          <th>Paid From</th>
          <th class="numeric">Amount</th>
          <th></th>
        </tr>
      </thead>

      <tbody>
        <%= for row <- @rows do %>
          <tr>
            <td>{row.date}</td>
            <td>
              <%= if row.source == :manual do %>
                <span
                  class="badge"
                  style="background:#e0e7ff;color:#3730a3;padding:2px 8px;border-radius:999px;font-size:0.75rem;font-weight:500;"
                >
                  Manual
                </span>
              <% else %>
                <span
                  class="badge"
                  style="background:#d1fae5;color:#065f46;padding:2px 8px;border-radius:999px;font-size:0.75rem;font-weight:500;"
                  title="Auto-synced from external service billing"
                >
                  Auto
                </span>
              <% end %>
            </td>
            <td>{row.description}</td>
            <td>{row.category || "—"}</td>
            <td>{row.expense_account_name || "—"}</td>
            <td>{row.paid_from_name || "—"}</td>
            <td class="numeric">{format_currency(row.amount_cents)}</td>
            <td>
              <%= if row.source == :manual do %>
                <div style="display: flex; gap: 0.5rem;">
                  <.link navigate={dp(@domain_path_prefix, "/expenses/#{row.id}")} class="btn">
                    View
                  </.link>
                  <.link
                    navigate={dp(@domain_path_prefix, "/expenses/#{row.id}/edit")}
                    class="btn"
                  >
                    Edit
                  </.link>
                  <.link
                    href={dp(@domain_path_prefix, "/expenses/#{row.id}")}
                    method="delete"
                    data-confirm="Are you sure you want to delete this expense?"
                    class="btn"
                    style="background-color: #dc2626; color: white;"
                  >
                    Delete
                  </.link>
                </div>
              <% else %>
                <span style="color: var(--text-muted); font-size: 0.875rem;">
                  Synced
                </span>
              <% end %>
            </td>
          </tr>
        <% end %>

        <%= if @rows == [] do %>
          <tr>
            <td colspan="8" style="text-align: center; padding: 2rem; color: var(--text-muted);">
              No expenses recorded yet.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
